# ─────────────────────────────────────────────────────────────────────────────
# TaskFlow environment configuration
# Copy this file to `.env` and fill in the values. Everything here is designed
# around open standards (PostgreSQL, the S3 API, OAuth) so you can self-host
# with no vendor lock-in. The defaults below match `docker-compose.yml`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (any PostgreSQL: Supabase, Neon, RDS, or self-hosted) ────────────
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# ── Auth.js / NextAuth (self-hosted, no third-party identity vendor) ──────────
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Public URL of the app. On Vercel this is set automatically.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, Wasabi…) ─────
# Set STORAGE_DRIVER=local to keep files on disk (great for dev / single-box
# self-host), or STORAGE_DRIVER=s3 to use any S3-compatible bucket.
STORAGE_DRIVER="local"            # "local" | "s3"
LOCAL_STORAGE_DIR=".localstorage" # used when STORAGE_DRIVER=local

S3_ENDPOINT="http://localhost:9000"   # MinIO default; leave blank for real AWS
S3_REGION="us-east-1"
S3_BUCKET="taskflow"
S3_ACCESS_KEY_ID="taskflow"
S3_SECRET_ACCESS_KEY="taskflow-secret"
S3_FORCE_PATH_STYLE="true"            # true for MinIO/R2, false for AWS S3

# ── Payments (Stripe by default; set PAYMENTS_DRIVER=manual to disable) ───────
PAYMENTS_DRIVER="manual"          # "stripe" | "manual"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Platform commission taken from each tasker payout (0.15 = 15%).
PLATFORM_COMMISSION_RATE="0.15"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="TaskFlow"
